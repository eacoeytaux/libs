# bash trash
# source <(curl -sN https://raw.githubusercontent.com/eacoeytaux/libs/master/bash_trash)

trash="$HOME/.trash/"
mkdir -p $trash

alias lstrash="ls -R $trash"
alias latrash="ls -laFR $trash"
alias lhtrash="lh -laFhR $trash"

function saferm {
    mkdir -p $trash
    mv $@ $trash &
}
function emptytrash {
    rm -rf $@ $trash* &
}
function restore {
    restore_dir=$2
        if [[ -z $restore_dir ]]; then
    restore_dir="./"
fi
    mv $trash$1 $restore_dir
}

# remove all files more than 3 weeks old at login
#rm -rf $(find $trash -mindepth 1 -mtime +21) # this seems a bit dangerous

# display whenever user logs in
if [[ $(find $trash -type f | wc -l) -gt 0 ]]; then
    echo "Current trash size: $(du -h --max-depth=0 $trash | cut -f1) ($(find $trash -type f | wc -l) files)"
fi
