# bash trash

# if not running interactively then don't do anything
[[ $- != *i* ]] && return

# source this file in bash session
alias srcbtrash="source <(curl -sN https://raw.githubusercontent.com/eacoeytaux/libs/master/bash_trash)"

# view this file
alias viewbtrash="view <(curl -sN https://raw.githubusercontent.com/eacoeytaux/libs/master/bash_trash)"

# cat this file
alias catbtrash="curl -sN https://raw.githubusercontent.com/eacoeytaux/libs/master/bash_trash"

# let user know "rm" should not be used
alias rm="echo \"rm is disabled, use saferm or \\rm instead\""

trash="$HOME/.trash/"
mkdir -p "$trash"

# replaces rm by moving files to designated trash ~ usage: saferm <list of files to delete>
function saferm {
    mkdir -p "$trash"
    mv "$@" "$trash"
}
alias srm="saferm"

# view files in trash
alias viewtrash="trashdisplay && echo \"Files in trash:\" && find $trash -type f | sed \"s|$trash|- |g\""

alias lstrash="ls -I . -I .. \"$trash\""
alias latrash="ls -laF -I . -I .. \"$trash\""
alias lhtrash="lh -laFh -I . -I .. \"$trash\""

# deletes all files/folders in trash ~ usage: rmtrash
function rmtrash {
    mkdir -p "$trash"
    find "$trash" -mindepth 1 -delete
}
alias emptytrash="rmtrash"

# moves file out of trash ~ usage: restore <file to restore> <dir to restore to (default ./)>
function restore {
    mv -i "$trash$1" "${2:-./}"
}

# remove all files more than 3 weeks old at login
#rm -rf $(find "$trash" -mindepth 1 -mtime +21) # this seems a bit dangerous

# display whenever user logs in
function trashdisplay {
    trash_file_count=$(find "$trash" -type f | wc -l)
    if [[ $trash_file_count -gt 0 ]]; then
        printf "current trash size: \033[1;31m$(du -h --max-depth=0 $trash | cut -f1) ($trash_file_count files)\033[0m\n"
    else
        echo "trash is empty"
    fi
}
trashdisplay
